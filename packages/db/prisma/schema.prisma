// CardVerse database schema
// Postgres + Prisma. See packages/shared for the canonical taxonomy & enums.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  customer
  manager
  admin
}

enum ProductType {
  BOOSTER_BOX
  DECK
  SINGLE_CARD
  ACCESSORY
}

enum Rarity {
  C
  UC
  R
  SR
  SSR
  UR
  SECRET
  PROMO
}

enum CardCondition {
  MINT
  NEAR_MINT
  EXCELLENT
  GOOD
  PLAYED
  DAMAGED
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum MarketplaceOrderStatus {
  PENDING_PAYMENT
  PAID_HELD
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXCEPTION
  FAILED
}

enum Carrier {
  THAILAND_POST
  KERRY
  FLASH
  JT
  NINJA_VAN
  DHL
  OTHER
}

enum NewsKind {
  NEWS
  EVENT
  SET_RELEASE
  PRICE_UPDATE
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ListingItemType {
  SINGLE_CARD
  BOX
}

enum NotificationType {
  ORDER_UPDATE
  SHIPMENT_UPDATE
  MARKETPLACE_SALE
  PRICE_ALERT
  PAYOUT
  SYSTEM
  CREDIT
  WITHDRAWAL
}

enum WalletTransactionType {
  TOP_UP
  ADMIN_GRANT
  PURCHASE
  ESCROW_HOLD
  ESCROW_RELEASE
  WITHDRAWAL
  WITHDRAWAL_REFUND
  REFUND
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------

model User {
  id          String  @id @default(cuid())
  clerkId     String  @unique
  email       String  @unique
  displayName String
  avatarUrl   String?
  role        Role    @default(customer)
  level       Int     @default(1)

  // Stripe Connect (seller payouts / escrow transfers)
  stripeConnectAccountId String?
  stripeConnectOnboarded Boolean @default(false)
  // Stripe customer (as a buyer)
  stripeCustomerId       String?

  // cached seller reputation
  sellerRating      Float @default(0)
  sellerRatingCount Int   @default(0)

  addresses        Address[]
  cart             Cart?
  orders           Order[]
  listings         Listing[]
  salesAsSeller    MarketplaceOrder[] @relation("SellerOrders")
  purchasesAsBuyer MarketplaceOrder[] @relation("BuyerOrders")
  trades           Trade[]            @relation("SellerTrades")
  collection       CollectionItem[]
  notifications    Notification[]
  offersMade       ListingOffer[]     @relation("OffersMade")
  reviewsWritten   SellerReview[]     @relation("ReviewAuthor")
  reviewsReceived  SellerReview[]     @relation("ReviewSeller")
  newsPosts        NewsPost[]
  wallet           Wallet?
  withdrawals      WithdrawalRequest[]
  topUpRequests    TopUpRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Wallet {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Int    @default(0) // satang, available credits
  heldBalance Int    @default(0) // satang, locked in marketplace escrow

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id            String              @id @default(cuid())
  walletId      String
  wallet        Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          WalletTransactionType
  amount        Int // positive = credit in, negative = debit out
  balanceAfter  Int
  description   String?
  referenceType String? // order | marketplace_order | withdrawal | topup
  referenceId   String?
  createdById   String?

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
}

model WithdrawalRequest {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int // satang
  status        WithdrawalStatus @default(PENDING)
  note          String?
  managerNote   String?
  processedById String?
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model TopUpRequest {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int // satang
  status        WithdrawalStatus @default(PENDING)
  note          String?
  managerNote   String?
  processedById String?
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName   String
  phone      String
  line1      String
  line2      String?
  district   String
  province   String
  postalCode String
  isDefault  Boolean @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Taxonomy (the catalog sellers must pick from)
// ---------------------------------------------------------------------------

model Category {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  nameTh    String
  emoji     String
  note      String?
  sortOrder Int     @default(0)

  subcategories Subcategory[]
  brands        Brand[]
  catalogItems  CatalogItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug       String
  name       String

  catalogItems CatalogItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model Brand {
  id         String    @id @default(cuid())
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  slug       String    @unique
  name       String

  catalogItems CatalogItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CardSet {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  releaseDate DateTime?

  catalogItems CatalogItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The canonical definition of a single card. Both store Products and
/// marketplace Listings reference a CatalogItem so prices can be aggregated.
model CatalogItem {
  id            String       @id @default(cuid())
  slug          String       @unique
  name          String
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  brandId       String?
  brand         Brand?       @relation(fields: [brandId], references: [id])
  setId         String?
  set           CardSet?     @relation(fields: [setId], references: [id])

  rarity      Rarity?
  cardNumber  String?
  releaseDate DateTime?
  imageUrl    String?
  images      String[]  @default([])
  attributes  Json?

  products    Product[]
  listings    Listing[]
  trades      Trade[]
  pricePoints PricePoint[]
  collection  CollectionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([brandId])
  @@index([name])
}

// ---------------------------------------------------------------------------
// First-party store
// ---------------------------------------------------------------------------

model Product {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  subtitle     String?
  description  String?
  type         ProductType @default(SINGLE_CARD)
  price        Int // stored in satang (THB * 100)
  stock        Int         @default(0)
  imageUrl     String?
  images       String[]    @default([])
  isPreOrder   Boolean     @default(false)
  isFeatured   Boolean     @default(false)
  isTrending   Boolean     @default(false)
  isNewArrival Boolean     @default(false)
  rarity       Rarity?
  soldCount    Int         @default(0)

  catalogItemId String?
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id])

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([catalogItemId])
  @@index([isTrending])
  @@index([isNewArrival])
}

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING)
  subtotal    Int
  shipping    Int         @default(0)
  discount    Int         @default(0)
  total       Int
  couponId    String?
  coupon      Coupon?     @relation(fields: [couponId], references: [id])
  addressId   String?
  address     Address?    @relation(fields: [addressId], references: [id])

  stripeSessionId       String?
  stripePaymentIntentId String?

  items    OrderItem[]
  shipment Shipment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  unitPrice Int
  quantity  Int

  createdAt DateTime @default(now())

  @@index([orderId])
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  percentOff     Int?
  amountOff      Int?
  maxRedemptions Int?
  timesRedeemed  Int       @default(0)
  active         Boolean   @default(true)
  expiresAt      DateTime?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Marketplace (user-to-user, escrow)
// ---------------------------------------------------------------------------

model Listing {
  id            String           @id @default(cuid())
  catalogItemId String
  catalogItem   CatalogItem      @relation(fields: [catalogItemId], references: [id])
  sellerId      String
  seller        User             @relation(fields: [sellerId], references: [id])
  itemType      ListingItemType  @default(SINGLE_CARD)
  price         Int // satang
  condition     CardCondition    @default(NEAR_MINT)
  grade         Int? // 1-10 for single cards only
  imageUrls     String[]         @default([])
  quantity      Int              @default(1)
  description   String?
  status        ListingStatus    @default(ACTIVE)

  orders MarketplaceOrder[]
  offers ListingOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([catalogItemId])
  @@index([sellerId])
  @@index([status])
  @@index([price])
}

model ListingOffer {
  id        String      @id @default(cuid())
  listingId String
  listing   Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User        @relation("OffersMade", fields: [buyerId], references: [id], onDelete: Cascade)
  amount       Int // satang
  message      String?
  status       OfferStatus @default(PENDING)
  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

model MarketplaceOrder {
  id        String                 @id @default(cuid())
  listingId String
  listing   Listing                @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User                   @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId  String
  seller    User                   @relation("SellerOrders", fields: [sellerId], references: [id])
  status    MarketplaceOrderStatus @default(PENDING_PAYMENT)

  amount       Int // satang, what buyer pays
  platformFee  Int @default(0)
  sellerPayout Int @default(0)
  quantity     Int @default(1)

  addressSnapshot Json?

  stripePaymentIntentId String?
  stripeTransferId      String?
  stripeChargeId        String?

  shippedAt    DateTime?
  deliveredAt  DateTime?
  completedAt  DateTime?
  releaseDueAt DateTime? // when escrow auto-releases

  shipment Shipment?
  trade    Trade?
  review   SellerReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([releaseDueAt])
}

/// A completed marketplace sale at a real transacted price.
/// Drives the market-price chart and the global "recent sales" feed.
model Trade {
  id                 String           @id @default(cuid())
  catalogItemId      String
  catalogItem        CatalogItem      @relation(fields: [catalogItemId], references: [id])
  marketplaceOrderId String           @unique
  marketplaceOrder   MarketplaceOrder @relation(fields: [marketplaceOrderId], references: [id])
  sellerId           String
  seller             User             @relation("SellerTrades", fields: [sellerId], references: [id])
  price              Int // satang, the actual purchase price
  soldAt             DateTime         @default(now())

  createdAt DateTime @default(now())

  @@index([catalogItemId, soldAt])
  @@index([soldAt])
}

/// Pre-aggregated daily price buckets per catalog item (filled by worker).
model PricePoint {
  id            String      @id @default(cuid())
  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  day           DateTime // day bucket (UTC midnight)
  avg           Int
  low           Int
  high          Int
  volume        Int

  @@unique([catalogItemId, day])
  @@index([catalogItemId, day])
}

model SellerReview {
  id       String           @id @default(cuid())
  orderId  String           @unique
  order    MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorId String
  author   User             @relation("ReviewAuthor", fields: [authorId], references: [id])
  sellerId String
  seller   User             @relation("ReviewSeller", fields: [sellerId], references: [id])
  rating   Int
  comment  String?

  createdAt DateTime @default(now())

  @@index([sellerId])
}

// ---------------------------------------------------------------------------
// Shipping
// ---------------------------------------------------------------------------

model Shipment {
  id                 String            @id @default(cuid())
  orderId            String?           @unique
  order              Order?            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  marketplaceOrderId String?           @unique
  marketplaceOrder   MarketplaceOrder? @relation(fields: [marketplaceOrderId], references: [id], onDelete: Cascade)
  carrier            Carrier?
  trackingNumber     String?
  status             ShipmentStatus    @default(PENDING)
  autoTrackingEnabled Boolean           @default(false)
  trackingSource     String?
  lastTrackedAt      DateTime?
  lastCourierSyncAt  DateTime?
  events             ShipmentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrier, trackingNumber])
  @@index([trackingNumber])
  @@index([carrier, status])
  @@index([lastCourierSyncAt])
}

model ShipmentEvent {
  id               String          @id @default(cuid())
  shipmentId       String?
  shipment         Shipment?       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  courier          Carrier?
  trackingNumber   String?
  status           ShipmentStatus
  rawStatus        String?
  normalizedStatus ShipmentStatus?
  accepted         Boolean         @default(true)
  ignoredReason    String?
  eventKey         String?
  rawPayload       Json?
  note             String?
  at               DateTime        @default(now())
  receivedAt       DateTime        @default(now())

  @@index([shipmentId])
  @@index([courier, trackingNumber])
  @@index([courier, eventKey])
}

// ---------------------------------------------------------------------------
// Collection, notifications, news
// ---------------------------------------------------------------------------

model CollectionItem {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  quantity      Int         @default(1)
  acquiredAt    DateTime    @default(now())

  @@unique([userId, catalogItemId])
  @@index([userId])
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType
  title  String
  body   String?
  link   String?
  read   Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
}

model NewsPost {
  id         String    @id @default(cuid())
  slug       String    @unique
  kind       NewsKind  @default(NEWS)
  title      String
  excerpt    String?
  body       String?
  imageUrl   String?
  published  Boolean   @default(true)
  eventDate  DateTime?
  sourceUrl  String?   @unique
  externalId String?
  sourceName String?
  importedAt DateTime?
  authorId   String?
  author     User?     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([published])
  @@index([sourceName])
}

// ---------------------------------------------------------------------------
// Platform settings (singleton-ish, admin-editable)
// ---------------------------------------------------------------------------

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}
