{
  "env": {
    "NEXT_PUBLIC_API_URL": "/backend",
    "NEXT_PUBLIC_WS_URL": "https://cardverse-five.vercel.app"
  },
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "https://cardverse-api-production.up.railway.app/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://cardverse-api-production.up.railway.app/socket.io/:path*"
    }
  ]
}
