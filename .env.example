# ============================================================
# CardVerse environment variables
# Copy to .env and fill in. apps read these via their own config.
#
# Local stack: keep REDIS_URL / API_URL / WEB_URL on localhost.
# Auth: set Clerk keys below to use Clerk sign-in (recommended).
# Leave Clerk keys blank only if you want demo dev-session login.
# ============================================================

# --- JSON data store (repo root data/) ---
CARDVERSE_DATA_DIR="./data"
LOCAL_UPLOAD_DIR="./data/uploads"

# --- One-time import from Supabase/PostgreSQL (optional) ---
# Get from Supabase: Project Settings → Database → Connection string (URI)
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Then run: pnpm db:import

# --- Redis (cache + BullMQ queue, local) ---
REDIS_URL="redis://localhost:6379"

# --- API (local) ---
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
# shared secret the worker and n8n use to call internal API endpoints
INTERNAL_API_SECRET="dev-internal-secret"

# --- Clerk (auth — cloud login, local data in JSON files) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
CLERK_JWT_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/account"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/account"

# --- Stripe + Connect (escrow marketplace) ---
# Prefer a restricted API key (rk_...) over a secret key.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# platform fee taken from each marketplace sale (percent)
MARKETPLACE_FEE_PERCENT=8
# days after "shipped" before escrow auto-releases to seller
ESCROW_AUTO_RELEASE_DAYS=7

# --- Flash Express tracking (optional; blank = demo/no-op) ---
FLASH_MCH_ID=""
FLASH_API_KEY=""
FLASH_API_BASE_URL="https://open-api.flashexpress.com"

# --- Local image uploads (stored under data/uploads/) ---
# CARDVERSE_DATA_DIR and LOCAL_UPLOAD_DIR are set above.

# --- Web (Next.js public) ---
# Browser traffic goes through Next.js on :3000; API still listens on :4000 locally.
NEXT_PUBLIC_API_URL="http://localhost:3000/backend"
NEXT_PUBLIC_WS_URL="http://localhost:3000"
