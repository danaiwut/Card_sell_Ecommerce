# ============================================================
# CardVerse environment variables
# Copy to .env and fill in. apps read these via their own config.
#
# Database: Supabase PostgreSQL (recommended). Redis stays local via Docker.
# Auth: set Clerk keys below to use Clerk sign-in (recommended).
# Leave Clerk keys blank only if you want demo dev-session login.
# ============================================================

# --- Database (Supabase PostgreSQL) ---
# Get password: Supabase Dashboard → Project Settings → Database → Reset database password
# Project: cardverse (ap-southeast-1) — https://supabase.com/dashboard/project/gwyzuektlgrzfxvnggcc
# Pooler URL for Prisma runtime queries (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.gwyzuektlgrzfxvnggcc:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL for Prisma migrations / db push (port 5432)
DIRECT_URL="postgresql://postgres.gwyzuektlgrzfxvnggcc:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- Supabase (database + image storage) ---
SUPABASE_URL="https://gwyzuektlgrzfxvnggcc.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://gwyzuektlgrzfxvnggcc.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key: Supabase Dashboard → Project Settings → API → service_role (server only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=""
# Storage bucket for product/catalog/news images (create as public bucket in Supabase Storage)
SUPABASE_STORAGE_BUCKET="cardverse"

# --- Redis (cache + BullMQ queue, local) ---
REDIS_URL="redis://localhost:6379"

# --- API (local) ---
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
# shared secret the worker and n8n use to call internal API endpoints
INTERNAL_API_SECRET="dev-internal-secret"

# --- Clerk (auth — cloud login, app data in Supabase Postgres) ---
# Run `pnpm exec clerk env pull` from apps/web to sync keys into apps/web/.env.local.
# Copy CLERK_SECRET_KEY (and CLERK_WEBHOOK_SECRET if using webhooks) to the repo root .env for the API.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
CLERK_JWT_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/account"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/account"

# --- Stripe + Connect (escrow marketplace) ---
# Prefer a restricted API key (rk_...) over a secret key.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# platform fee taken from each marketplace sale (percent)
MARKETPLACE_FEE_PERCENT=8
# days after "shipped" before escrow auto-releases to seller
ESCROW_AUTO_RELEASE_DAYS=7

# --- Flash Express tracking (optional; blank = demo/no-op) ---
FLASH_MCH_ID=""
FLASH_API_KEY=""
FLASH_API_BASE_URL="https://open-api.flashexpress.com"

# --- Web (Next.js public) ---
# Browser traffic goes through Next.js on :3000; API still listens on :4000 locally.
NEXT_PUBLIC_API_URL="http://localhost:3000/backend"
NEXT_PUBLIC_WS_URL="http://localhost:3000"
